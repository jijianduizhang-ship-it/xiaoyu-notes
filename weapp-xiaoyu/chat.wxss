/* 聊天页面样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-top: env(safe-area-inset-top);
  border-bottom: 1rpx solid #E5E5E5;
  flex-shrink: 0;
}

.nav-back { font-size: 48rpx; color: #333; font-weight: 300; width: 60rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 500; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.nav-more { font-size: 36rpx; color: #666; width: 60rpx; text-align: right; }

/* AI角色信息 */
.ai-info {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 16rpx 30rpx;
  flex-shrink: 0;
}

.ai-avatar-small {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-right: 16rpx;
  overflow: hidden;
}

.ai-intro {
  flex: 1;
  font-size: 24rpx;
  opacity: 0.9;
}

/* VIP横幅 */
.vip-banner {
  background: linear-gradient(135deg, #FF6B6B, #FF4757);
  color: #fff;
  padding: 16rpx 30rpx;
  font-size: 24rpx;
  text-align: center;
  flex-shrink: 0;
}

/* 聊天内容 */
.chat-content {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  -webkit-overflow-scrolling: touch;
}

.load-more { text-align: center; padding: 20rpx; color: #999; font-size: 24rpx; }

.welcome-tip { text-align: center; padding: 30rpx; color: #999; font-size: 26rpx; }

.messages { padding-bottom: 20rpx; }

/* 消息项 */
.msg-item { margin-bottom: 30rpx; display: flex; align-items: flex-start; }
.msg-send { flex-direction: row-reverse; }

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  overflow: hidden;
  color: #fff;
}

.my-avatar {
  background: linear-gradient(135deg, #00C896, #00A878);
  margin-left: 16rpx;
}

.my-avatar image { width: 100%; height: 100%; border-radius: 50%; }

.ai-avatar {
  background: linear-gradient(135deg, #667eea, #764ba2);
  margin-right: 16rpx;
  font-size: 20rpx;
}

/* 气泡 */
.msg-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  line-height: 1.6;
}

.send-bubble {
  background: linear-gradient(135deg, #00C896, #00A878);
  color: #fff;
  margin-left: 16rpx;
  border-bottom-right-radius: 8rpx;
}

.receive-bubble {
  background: #fff;
  color: #333;
  margin-right: 16rpx;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.msg-text { font-size: 28rpx; line-height: 1.6; word-break: break-all; }
.msg-text-kr { font-size: 28rpx; color: #333; line-height: 1.6; margin-bottom: 8rpx; display: block; word-break: break-all; }
.msg-text-cn { font-size: 24rpx; color: #666; line-height: 1.5; display: block; padding-top: 8rpx; border-top: 1rpx solid #E5E5E5; margin-top: 8rpx; }
.thinking { color: #999; font-style: italic; font-size: 28rpx; }

/* AI提示 */
.ai-tip { text-align: center; font-size: 20rpx; color: #999; padding: 10rpx; background: #F5F5F5; flex-shrink: 0; }

/* 输入区域 */
.input-area { background: #fff; border-top: 1rpx solid #E5E5E5; flex-shrink: 0; transition: all 0.2s; }

.func-bar { display: flex; padding: 16rpx 20rpx; border-bottom: 1rpx solid #F0F0F0; gap: 40rpx; }
.func-item { display: flex; align-items: center; gap: 8rpx; font-size: 28rpx; color: #666; }
.func-label { font-size: 24rpx; }

.input-box { display: flex; align-items: center; padding: 16rpx 20rpx; gap: 16rpx; }

.more-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%; background: #F5F5F5;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: #666; font-weight: 300; transition: all 0.2s;
}
.more-btn:active { background: #E5E5E5; transform: scale(0.95); }

.chat-input {
  flex: 1; height: 72rpx; background: #F5F5F5; border-radius: 36rpx;
  padding: 0 30rpx; font-size: 28rpx; color: #333;
}
.chat-input::placeholder { color: #999; }

.send-btn {
  height: 64rpx; padding: 0 32rpx; background: #ddd; color: #fff;
  border-radius: 32rpx; font-size: 26rpx; display: flex; align-items: center;
  justify-content: center; transition: all 0.2s;
}
.send-btn.active { background: linear-gradient(135deg, #00C896, #00A878); }
.send-btn.active:active { opacity: 0.8; transform: scale(0.95); }
